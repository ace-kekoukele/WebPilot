# WebPilot .npmrc — 配国内 npm 镜像 (npm registry 经常超时)
# 用户装 electron / vite / react 等 GUI 包时自动走国内镜像
#
# 如果某天你想用官方源, 临时:  npm install xxx --registry=https://registry.npmjs.org

# 主镜像 (npmmirror)
registry=https://registry.npmmirror.com

# 备用镜像 (若 npmmirror 也不通, 取消下面这行注释换 taobao)
# registry=https://registry.npm.taobao.org

# Electron 二进制下载走国内镜像
# (electron 不走 registry, 它从 GitHub releases 拉, 这里指向 npmmirror 的 electron 镜像)
electron_mirror=https://npmmirror.com/mirrors/electron/

# 国内 Node.js 二进制 (镜像下载 node 本身时用)
# 不需要可以删掉
# disturl=https://npmmirror.com/dist

# 提升安装速度 + 兼容老 npm 客户端
legacy-peer-deps=true
strict-ssl=false
