    "test:watch": "vitest",
    "check": "node --check daemon/main.js electron/main.cjs electron/preload.cjs electron/menu.cjs electron/tray.cjs",
    "daemon": "node daemon/main.js",
    "electron": "electron electron/main.cjs",
    "dist": "electron-builder --win",
    "dist:dir": "electron-builder --dir"
  },
